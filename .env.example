# Copy to .env for local dev. On Render, set these in the dashboard / render.yaml.

# Supabase Postgres — use the "Session pooler" connection string (port 5432,
# IPv4). Dashboard: Project -> Connect -> Session pooler. Works for both the
# app runtime and `prisma migrate`.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase Storage (scanned invoices). Dashboard: Project -> Settings -> API.
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""          # service_role key (secret — server only)
SUPABASE_BUCKET="invoices"            # create a PRIVATE bucket with this name

# Shared team login password
APP_PASSWORD="change-me"

# Long random string used to sign the session cookie
SESSION_SECRET="change-me-to-a-long-random-string"

# Anthropic Claude API (vision parsing)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
