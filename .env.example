# Copy to .env for local dev. On Render, set these in the dashboard / render.yaml.

# Local SQLite. On Render use the persistent disk: file:/var/data/dev.db
DATABASE_URL="file:./dev.db"

# Where uploaded invoices are stored. On Render: /var/data/uploads
# (leave unset locally -> defaults to <project>/uploads)
# UPLOAD_DIR="/var/data/uploads"

# Shared team login password
APP_PASSWORD="change-me"

# Long random string used to sign the session cookie
SESSION_SECRET="change-me-to-a-long-random-string"

# Anthropic Claude API (vision parsing)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
